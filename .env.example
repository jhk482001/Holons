# ========= Database (Postgres) =========
POSTGRES_DB=agent_company
POSTGRES_USER=agent_company
POSTGRES_PASSWORD=devpassword
POSTGRES_PORT=5432

# Full DATABASE_URL used by the app (auto-built from above in docker-compose)
DATABASE_URL=postgresql://agent_company:devpassword@localhost:5432/agent_company

# ========= pgAdmin (optional UI) =========
PGADMIN_EMAIL=admin@localhost
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ========= AWS Bedrock =========
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=ap-northeast-1

# ========= Flask =========
SECRET_KEY=change-this-in-production
PORT=8087
