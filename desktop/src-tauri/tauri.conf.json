{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Holons",
  "version": "1.0.0",
  "identifier": "com.holons.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "fullscreen": false,
        "maximizable": true,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "width": 1440,
        "height": 900,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "sidecar/agent-company-backend": "agent-company-backend"
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
