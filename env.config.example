# Copy to `env.config` and fill in your own values.
# `env.config` is git-ignored — DO NOT commit real secrets.
#
# This file is used by the managed/enterprise deployment (backend.app),
# not by the personal desktop build (which uses SQLite via backend.standalone).

# -------- Database (managed Postgres / RDS / etc.) --------
DB_HOST=your-db-host.example.com
DB_PORT=5432
DB_NAME=agent_company
DB_USER=agent_company
DB_PASSWORD=REPLACE_ME

# -------- AWS Bedrock (optional — only if you use the Bedrock adapter) --------
AWS_ACCESS_KEY=REPLACE_ME
AWS_SECRET_KEY=REPLACE_ME
AWS_REGION=us-east-1

# -------- Asset encryption --------
# Base64 Fernet key. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ASSET_ENCRYPTION_KEY=REPLACE_ME
